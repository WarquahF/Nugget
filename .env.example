# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# Email Configuration (Gmail with App Password)
# Get app password at: https://myaccount.google.com/apppasswords
REACT_APP_EMAIL_USER=your_email@gmail.com
REACT_APP_EMAIL_PASS=your_app_password

# Zoom SDK Configuration
# Get SDK credentials at: https://marketplace.zoom.us
REACT_APP_ZOOM_SDK_KEY=
REACT_APP_ZOOM_ZOOM_PASSWORD=

# ElevenLabs API (for text-to-speech)
# Get API key at: https://elevenlabs.io
REACT_APP_ELEVENLABS_API_KEY=

# LLM Model Path (relative or absolute)
REACT_APP_LLM_MODEL_PATH=../models/llama3.gguf

# Backend API (if using a backend server)
REACT_APP_API_URL=http://localhost:5000
